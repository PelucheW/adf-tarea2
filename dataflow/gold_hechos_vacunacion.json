{
	"name": "gold_hechos_vacunacion",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_vacunacion_consolidada",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          id_transaccion_origen as string,",
				"          paciente_id as string,",
				"          documento_identidad as string,",
				"          nombres as string,",
				"          primer_apellido as string,",
				"          segundo_apellido as string,",
				"          genero as string,",
				"          fecha_nacimiento as date,",
				"          municipio_residencia as string,",
				"          comunidad_indigena as string,",
				"          fecha_vacunacion as timestamp,",
				"          vacuna_id as string,",
				"          vacuna_nombre_original as string,",
				"          numero_dosis as integer,",
				"          establecimiento_id as string,",
				"          nombre_establecimiento_original as string,",
				"          departamento_registro as string,",
				"          numero_lote as string,",
				"          temperatura_conservacion as decimal(5,2),",
				"          edad_dias_aplicacion as integer,",
				"          via_aplicacion as string,",
				"          aplicacion_oportuna as boolean,",
				"          origen_datos as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT \\n    CAST(CONVERT(VARCHAR(8), CAST(fecha_vacunacion AS DATE), 112) AS INT) AS fecha_key,\\n    paciente_id AS paciente_id,                 -- Nos servirá en ADF para cruzar con la Dim\\n    vacuna_id AS vacuna_id,                     -- Nos servirá en ADF para cruzar con la Dim\\n    establecimiento_id AS establecimiento_id,   -- Nos servirá en ADF para cruzar con la Dim\\n    numero_dosis AS numero_dosis,\\n    edad_dias_aplicacion AS edad_dias_aplicacion,\\n    1 AS cantidad_aplicaciones,                  -- Métrica para contar rápido en Power BI\\n    lote_vacuna AS lote_vacuna,\\n    registro_id AS id_registro_origen\\nFROM silver.vacunacion_consolidada\\nWHERE registro_id IS NOT NULL',",
				"     format: 'query') ~> source1"
			]
		}
	}
}